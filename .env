# Symfony 8 Development Environment Configuration
# Default configuration - DO NOT COMMIT TO VERSION CONTROL

# Database Configuration
DATABASE_TYPE=mysql
DATABASE_NAME=symfony_db
DATABASE_USER=symfony
DATABASE_PASSWORD=symfony
DATABASE_ROOT_PASSWORD=secret

# Database URLs
DATABASE_URL="mysql://symfony:symfony@mysql:3306/symfony_db?serverVersion=8.0&charset=utf8mb4"
# For PostgreSQL use:
# DATABASE_URL="pgsql://symfony:symfony@postgres:5432/symfony_db"

# Symfony Application
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=ThisTokenIsNotSoSecretChangeItInProduction

# Development Server
WEB_SERVER_PORT=8000
PHPMYADMIN_PORT=8080
MYSQL_PORT=3307
POSTGRES_PORT=5432

# Xdebug Configuration
XDEBUG_ENABLE=true
XDEBUG_MODE=develop,coverage,debug,profile
XDEBUG_IDE_KEY=VSCODE
XDEBUG_HOST=host.docker.internal

# Workspace Configuration
WORKSPACE_USER_ID=1000
WORKSPACE_GROUP_ID=1000

# MailHog Configuration
MAILHOG_PORT=8025
MAILHOG_SMTP_PORT=1025

# Timezone
TIMEZONE=UTC
