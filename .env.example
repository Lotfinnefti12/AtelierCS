# Symfony 8 Development Environment Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_TYPE=mysql
DATABASE_NAME=symfony_db
DATABASE_USER=symfony
DATABASE_PASSWORD=symfony
DATABASE_ROOT_PASSWORD=secret

# Symfony Application
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=ThisTokenIsNotSoSecretChangeIt

# Database URLs (automatically configured based on DATABASE_TYPE)
# DATABASE_URL will be generated based on the selected database type

# Development Server
WEB_SERVER_PORT=8000
PHPMYADMIN_PORT=8080
MYSQL_PORT=3306
POSTGRES_PORT=5432

# Xdebug Configuration
XDEBUG_ENABLE=true
XDEBUG_MODE=develop,coverage,debug,profile
XDEBUG_IDE_KEY=VSCODE
XDEBUG_HOST=host.docker.internal

# Workspace Configuration
WORKSPACE_USER=vscode
WORKSPACE_GROUP=vscode

# Timezone
TIMEZONE=UTC